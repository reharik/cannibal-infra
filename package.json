{
  "name": "photo-app",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/api",
    "apps/media-worker",
    "apps/web",
    "packages/contracts"
  ],
  "scripts": {
    "build": "nx run-many -t build",
    "build:clean": "nx reset && nx run-many -t build",
    "build:web:production": "nx run web:build:production",
    "dance": "npm run format && npm run gen:all && npm run build && npm run lint && npm run test",
    "db:migrate:prod": "docker compose -f docker-compose.yml exec -T api npm run db:migrate:local --workspace=@app/api",
    "db:seed:prod": "docker compose -f docker-compose.yml exec -T api npm run db:seed:local --workspace=@app/api",
    "dev:api": "nx run api:serve:with-contracts",
    "dev:web": "nx run web:serve",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "gen:all": "npm run gen:ioc; npm run gen:gql; npm run gen:enums",
    "gen:enums": "npm run gen:graphql:enums --workspace=@packages/contracts",
    "gen:gql": "npm run gen:graphql --workspace=@app/api; npm run codegen --workspace=@app/web",
    "gen:gql:be": "npm run gen:graphql --workspace=@app/api",
    "gen:gql:fe": "npm run codegen --workspace=@app/web",
    "gen:ioc": "npm run gen:container --workspace=@app/api",
    "graph": "nx graph",
    "ioc:inspect": "ioc inspect",
    "ioc:inspect:discovery": "ioc inspect --discovery",
    "lint": "nx run-many -t lint --projects=api,web,contracts",
    "lint:fix": "nx run-many -t lint --projects=api,web,contracts -- --fix",
    "nuke": "rimraf node_modules api/node_modules web/node_modules contracts/node_modules api/dist web/dist contracts/dist dist .nx/cache && npm install && npm run build:clean && npm run lint && npm run test",
    "nuke:lite": "rimraf api/dist web/dist contracts/dist dist .nx/cache && npm run build:clean && npm run lint && npm run test",
    "nx": "nx",
    "seed:dev-admin": "npm run seed:dev-admin --workspace=@app/api",
    "test": "NODE_OPTIONS='--experimental-vm-modules' nx run-many -t test --all",
    "test:ci": "NODE_OPTIONS='--experimental-vm-modules' nx run-many -t test --all -- --runInBand",
    "test:watch": "NODE_OPTIONS='--experimental-vm-modules' nx run-many -t test --all -- --watch"
  },
  "dependencies": {
    "@reharik/smart-enum": "^0.3.1",
    "dotenv": "^16.6.1",
    "koa": "^3.1.1",
    "parse-fetch": "^0.0.6",
    "typia": "^9.7.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.34.0",
    "@jest/globals": "^30.1.2",
    "@nx/esbuild": "21.4.1",
    "@nx/eslint": "^21.4.1",
    "@nx/jest": "^21.4.1",
    "@nx/js": "21.4.1",
    "@nx/react": "21.4.1",
    "@nx/vite": "21.4.1",
    "@reharik/graphql-codegen-smart-enum": "^0.2.2",
    "@testing-library/jest-dom": "^6.8.0",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@typescript-eslint/eslint-plugin": "^8.42.0",
    "@typescript-eslint/parser": "^8.42.0",
    "eslint": "^9.34.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-formatter-stylish": "^8.40.0",
    "eslint-plugin-import-x": "^4.16.1",
    "eslint-plugin-jest": "^28.11.0",
    "eslint-plugin-prettier": "^5.2.3",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "is-generator-function": "1.1.0",
    "jest": "^30.1.3",
    "jest-environment-jsdom": "^30.1.2",
    "nx": "21.4.1",
    "prettier": "^3.6.2",
    "prettier-plugin-organize-imports": "^4.2.0",
    "prettier-plugin-packagejson": "^2.5.19",
    "rimraf": "^6.0.1",
    "sqlite3": "^5.1.7",
    "ts-jest": "^29.4.1",
    "ts-node": "^10.9.2",
    "ts-patch": "^3.3.0",
    "tslib": "^2.6.3",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.42.0"
  }
}

{
  "extends": "../../../tsconfig.json",
  "compilerOptions": {
    "paths": {},
    "outDir": "./dist",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "composite": true,
    "noEmit": false,
    "skipLibCheck": true,
    "strictNullChecks": true,
    "strict": true
  },
  "include": ["src/**/*.ts"],
  "exclude": ["dist", "node_modules", "src/tests/**"]
}

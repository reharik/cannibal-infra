{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "outDir": "./dist",
    "noEmit": true,
    "allowJs": true,
    "baseUrl": "../..",
    "paths": {
      "@packages/contracts": ["packages/contracts/dist/src/index"],
      "@packages/contracts/*": ["packages/contracts/dist/src/*"]
    },
    "skipLibCheck": true,
    "strictNullChecks": true,
    "strict": true,
    "isolatedModules": true
  },
  "include": ["src/**/*.ts"],
  "exclude": ["dist", "node_modules"]
}

{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "outDir": "./dist",
    "noEmit": true,
    "allowJs": true,
    "baseUrl": "../..",
    "paths": {
      "@packages/contracts": ["packages/foundation/contracts/src/index.ts"],
      "@packages/infrastructure": ["packages/foundation/infrastructure/src/index.ts"],
      "@packages/media-core": ["packages/context/media-core/src/index.ts"]
    },
    "skipLibCheck": true,
    "strictNullChecks": true,
    "strict": true,
    "isolatedModules": true
  },
  "include": ["src/**/*.ts"],
  "exclude": ["dist", "node_modules"]
}

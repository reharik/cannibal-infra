{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "outDir": "./dist",
    "noEmit": true,
    "allowJs": true,
    "baseUrl": "../..",
    "paths": {
      "@packages/contracts": ["packages/foundation/contracts/src/index"],
      "@packages/media-core": ["packages/context/media-core/src/index"]
    },
    "types": ["jest", "vite/client"],
    "plugins": [
      {
        "transform": "typia/lib/transform"
      }
    ],
    "skipLibCheck": true,
    "strictNullChecks": true,
    "strict": true,
    "isolatedModules": true
  },
  "include": [
    "src/**/*.ts",
    "db/**/*.ts",
    "../../packages/context/media-core/src/types/types.ts",
    "../../packages/context/media-core/src/application/media/s3MediaStorage.ts"
  ],
  "exclude": ["jest.*", "dist", "node_modules", "src/_original/**"]
}

{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "outDir": "./dist",
    "noEmit": true,
    "allowJs": true,
    "baseUrl": "../..",
    "paths": {
      "@packages/contracts": ["packages/contracts/dist/src/index"],
      "@packages/contracts/*": ["packages/contracts/dist/src/*"]
    },
    "types": ["jest", "vite/client"],
    "plugins": [
      {
        "transform": "typia/lib/transform"
      }
    ],
    "skipLibCheck": true,
    "strictNullChecks": true,
    "strict": true,
    "isolatedModules": true
  },
  "include": ["src/**/*.ts", "db/**/*.ts"],
  "exclude": ["jest.*", "dist", "node_modules", "src/_original/**"]
}

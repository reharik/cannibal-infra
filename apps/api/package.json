{
  "name": "@app/api",
  "private": true,
  "description": "PhotoApp API",
  "keywords": [],
  "license": "ISC",
  "author": "",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "nx build api",
    "build:dev": "nx build api --configuration=development",
    "build:prod": "nx build api --configuration=production",
    "db:make": "NODE_OPTIONS=--import=tsx npx knex --knexfile src/knexfile.ts migrate:make",
    "db:migrate:local": "NODE_OPTIONS=--import=tsx npx knex --knexfile src/knexfile.ts migrate:latest",
    "db:migrate:prod": "knex --knexfile dist/knexfile.js migrate:latest",
    "db:rollback": "NODE_OPTIONS=--import=tsx npx knex --knexfile src/knexfile.ts migrate:rollback",
    "db:seed:local": "NODE_OPTIONS=--import=tsx npx knex --knexfile src/knexfile.ts seed:run",
    "seed:dev-admin": "tsx src/localScripts/seedDevAdmin.ts",
    "seed:dev-admin:clean": "tsx src/localScripts/cleanDevAdmin.ts",
    "dev": "nodemon",
    "gen:container": "rimraf src/di/awilix.autoload.d.ts && tsx src/codeGen/gen-awilix-container.ts",
    "gen:graphql": "graphql-codegen",
    "lint": "nx run api:lint",
    "serve": "nx serve api",
    "start": "node dist/index.js",
    "start:dev": "node --enable-source-maps dist/index.js",
    "test": "NODE_OPTIONS='--experimental-vm-modules' nx test api --runInBand --detectOpenHandles"
  },
  "dependencies": {
    "@graphql-tools/code-file-loader": "^8.1.28",
    "@graphql-tools/graphql-file-loader": "^8.1.12",
    "@graphql-tools/load": "^8.1.8",
    "@graphql-tools/load-files": "^7.0.1",
    "@graphql-tools/merge": "^9.1.7",
    "@graphql-tools/schema": "^10.0.31",
    "@koa/bodyparser": "^5.1.1",
    "@koa/cors": "^5.0.0",
    "@koa/router": "^13.1.0",
    "@packages/contracts": "*",
    "awilix": "^12.1.1",
    "bcryptjs": "^3.0.3",
    "case-anything": "^3.1.2",
    "dotenv": "^16.6.1",
    "graphql": "^16.13.1",
    "graphql-yoga": "^5.18.1",
    "jsonwebtoken": "^9.0.3",
    "knex": "^3.1.0",
    "knex-stringcase": "^1.6.0",
    "koa": "2.16.2",
    "koa-body": "^6.0.1",
    "luxon": "^3.7.1",
    "pg": "^8.16.3",
    "smart-enums": "^0.0.22",
    "uuid": "^11.1.0",
    "winston": "^3.15.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@eddeee888/gcg-typescript-resolver-files": "0.11.0",
    "@graphql-codegen/cli": "^5.0.3",
    "@graphql-codegen/schema-ast": "^4.1.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/jest": "^29.5.14",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/knex": "^0.15.2",
    "@types/koa": "^2.15.0",
    "@types/koa__cors": "^5.0.0",
    "@types/koa__router": "^12.0.4",
    "@types/luxon": "^3.7.1",
    "@types/node": "^22.18.0",
    "fast-glob": "^3.3.3",
    "nodemon": "^3.1.10",
    "rimraf": "^6.0.1",
    "supertest": "^7.0.0",
    "ts-patch": "^3.3.0",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2",
    "vite": "^6.3.5",
    "vite-tsconfig-paths": "^5.1.4"
  }
}

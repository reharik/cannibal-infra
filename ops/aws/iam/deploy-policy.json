{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "DeployBucketList",
      "Effect": "Allow",
      "Action": [
        "s3:ListBucket"
      ],
      "Resource": "arn:aws:s3:::YOUR_DEPLOY_BUCKET"
    },
    {
      "Sid": "DeployObjectWrite",
      "Effect": "Allow",
      "Action": [
        "s3:GetObject",
        "s3:PutObject",
        "s3:DeleteObject"
      ],
      "Resource": "arn:aws:s3:::YOUR_DEPLOY_BUCKET/*"
    }
  ]
}

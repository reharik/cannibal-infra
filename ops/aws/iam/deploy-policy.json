{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "DeployBucketList",
      "Effect": "Allow",
      "Action": [
        "s3:ListBucket"
      ],
      "Resource": "arn:aws:s3:::network-deploy-709865789463-us-east-1"
    },
    {
      "Sid": "DeployBucketObjects",
      "Effect": "Allow",
      "Action": [
        "s3:GetObject",
        "s3:PutObject",
        "s3:DeleteObject"
      ],
      "Resource": "arn:aws:s3:::network-deploy-709865789463-us-east-1/*"
    },
    {
      "Sid": "EC2DescribeForDeployTargets",
      "Effect": "Allow",
      "Action": ["ec2:DescribeInstances"],
      "Resource": "*"
    },
    {
      "Sid": "RunShellScriptViaSSM",
      "Effect": "Allow",
      "Action": ["ssm:SendCommand"],
      "Resource": [
        "arn:aws:ssm:us-east-1::document/AWS-RunShellScript",
        "arn:aws:ec2:us-east-1:709865789463:instance/*"
      ]
    },
    {
      "Sid": "SSMPollCommandInvocations",
      "Effect": "Allow",
      "Action": ["ssm:GetCommandInvocation", "ssm:ListCommandInvocations"],
      "Resource": "*"
    }
  ]
}
